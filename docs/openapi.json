                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}/cancel": {
      "post": {
        "summary": "Cancel Job Endpoint",
        "description": "Cancel an active (queued or running) job.\nMarks the job as failed with message 'Cancelled by user'.\nReturns 404 if job not found, 409 if job is not active (already finished).",
