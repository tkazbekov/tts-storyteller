{
  "openapi": "3.1.0",
  "info": {
    "title": "Qwen3-TTS Home API",
    "version": "0.1.0",
    "description": "Local API for managing voices, story templates, and TTS generation."
  },
  "servers": [
    { "url": "http://localhost:8000" }
  ],
  "paths": {
    "/voices": {
      "get": {
        "summary": "List all available voices",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Voice" }
                }
              }
            }
          }
        }
      }
    },
    "/voices/{voiceId}": {
      "get": {
        "summary": "Get voice details by ID",
        "parameters": [
          { "$ref": "#/components/parameters/voiceId" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Voice" }
              }
            }
          },
          "404": { "description": "Voice not found" }
        }
      }
    },
    "/stories": {
      "get": {
        "summary": "List all story IDs",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new story template",
        "description": "Create a new story template. Use the 'casting' field to map roleIds (as strings) to voiceIds. Resolution order: line.actorId → casting[roleId] → defaultVoiceId. Example casting: {'0': 'narrator_male', '1': 'woman'}.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StoryTemplate" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StoryTemplate" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "409": { "description": "Story already exists" }
        }
      }
    },
    "/stories/{storyId}": {
      "get": {
        "summary": "Get story template by ID",
        "parameters": [
          { "$ref": "#/components/parameters/storyId" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StoryTemplate" }
              }
            }
          },
          "404": { "description": "Story not found" }
        }
      },
      "put": {
        "summary": "Replace an existing story template",
        "parameters": [
          { "$ref": "#/components/parameters/storyId" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/StoryTemplate" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StoryTemplate" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "404": { "description": "Story not found" }
        }
      }
    },
    "/stories/{storyId}/render": {
      "post": {
        "summary": "Resolve roles to voices for a story",
        "description": "Returns a preview of voice assignments showing which voice will be used for each line. Resolution order: line.actorId → casting[roleId] → defaultVoiceId. Use this endpoint to verify voice assignments before generating audio.",
        "parameters": [
          { "$ref": "#/components/parameters/storyId" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ResolvedLine" }
                }
              }
            }
          },
          "400": { "description": "Resolution error" },
          "404": { "description": "Story not found" }
        }
      }
    },
    "/stories/{storyId}/generate": {
      "post": {
        "summary": "Start audio generation for a story",
        "parameters": [
          { "$ref": "#/components/parameters/storyId" },
          {
            "name": "cancel_existing",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false },
            "description": "If true, cancel any active job for this story and start a new one"
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "404": { "description": "Story not found" },
          "409": { "description": "Job already active for this story (unless cancel_existing=true)" }
        }
      }
    },
    "/jobs": {
      "get": {
        "summary": "List active (queued/running) jobs",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Job" }
                }
              }
            }
          }
        }
      }
    },
    "/jobs/{jobId}": {
      "get": {
        "summary": "Get job status by ID",
        "parameters": [
          { "$ref": "#/components/parameters/jobId" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "404": { "description": "Job not found" }
        }
      }
    },
    "/jobs/{jobId}/cancel": {
      "post": {
        "summary": "Cancel an active (queued or running) job",
        "parameters": [
          { "$ref": "#/components/parameters/jobId" }
        ],
        "responses": {
          "200": {
            "description": "Job cancelled",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Job" }
              }
            }
          },
          "404": { "description": "Job not found" },
          "409": { "description": "Job is not active (already finished)" }
        }
      }
    },
    "/audio/stories/{storyId}/full.wav": {
      "get": {
        "summary": "Download the concatenated audio file for a story",
        "parameters": [
          { "$ref": "#/components/parameters/storyId" }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "audio/wav": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": { "description": "Audio not found" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "voiceId": {
        "name": "voiceId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "storyId": {
        "name": "storyId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "jobId": {
        "name": "jobId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "schemas": {
      "Voice": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "promptPath": { "type": "string", "nullable": true },
          "refAudioPath": { "type": "string", "nullable": true }
        }
      },
      "Role": {
        "type": "object",
        "additionalProperties": false,
        "required": ["roleId", "name"],
        "properties": {
          "roleId": { "type": "integer", "minimum": 0 },
          "name": { "type": "string" },
          "notes": { "type": "string", "nullable": true }
        }
      },
      "StoryLine": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roleId", "line"],
        "properties": {
          "id": { "type": "integer", "minimum": 0, "description": "Unique line identifier" },
          "roleId": { "type": "integer", "minimum": 0, "description": "Role that speaks this line" },
          "line": { "type": "string", "description": "The text to speak" },
          "extra": { "type": "string", "nullable": true, "description": "Performance hint (e.g., 'curious, excited')" },
          "actorId": { "type": "string", "nullable": true, "description": "Optional per-line voice override. Highest priority: actorId → casting[roleId] → defaultVoiceId" }
        }
      },
      "StoryTemplate": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schemaVersion", "title", "defaultVoiceId", "roles", "lines"],
        "description": "A story template with roles and lines. Voice assignment resolution order (for each line): 1) line.actorId (if present), 2) casting[str(roleId)] (if present), 3) defaultVoiceId (fallback).",
        "properties": {
          "schemaVersion": { "type": "integer", "const": 1, "description": "Schema version" },
          "title": { "type": "string", "description": "Story title" },
          "defaultVoiceId": { "type": "string", "description": "Fallback voice ID used when a role has no casting assignment and line has no actorId" },
          "roles": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Role" },
            "description": "Story roles"
          },
          "casting": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "nullable": true,
            "description": "Optional map of roleId (as string key) to voiceId (string value). Example: {'0': 'narrator_male', '1': 'woman'}. Keys must be string representations of roleId integers.",
            "example": {
              "0": "narrator_male",
              "1": "woman",
              "2": "child"
            }
          },
          "lines": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/StoryLine" },
            "description": "Story lines"
          }
        }
      },
      "ResolvedLine": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "roleId", "voiceId", "line"],
        "description": "A story line with resolved voice assignment. Result of resolving a StoryLine using: actorId → casting[roleId] → defaultVoiceId",
        "properties": {
          "id": { "type": "integer", "description": "Line identifier" },
          "roleId": { "type": "integer", "description": "Role identifier" },
          "voiceId": { "type": "string", "description": "Resolved voice ID that will be used for this line" },
          "line": { "type": "string", "description": "The text to speak" },
          "extra": { "type": "string", "nullable": true, "description": "Performance hint" }
        }
      },
      "GenerateRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "concat": { "type": "boolean", "default": false },
          "concatOut": { "type": "string", "nullable": true }
        }
      },
      "Job": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "status"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "running", "succeeded", "failed"] },
          "storyId": { "type": "string", "nullable": true },
          "message": { "type": "string", "nullable": true },
          "outputPath": { "type": "string", "nullable": true },
          "requestParams": {
            "type": "object",
            "additionalProperties": true,
            "nullable": true
          }
        }
      }
    }
  }
}
