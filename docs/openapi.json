{
  "openapi": "3.1.0",
  "info": {
    "title": "TTS Storyteller API",
    "description": "Multi-backend TTS API supporting Qwen3-TTS and VibeVoice for voice-driven story generation with parallel execution",
    "version": "0.1.0"
  },
