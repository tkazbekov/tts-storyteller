              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stories/{storyId}/render": {
      "post": {
        "summary": "Render Story Endpoint",
        "description": "Resolve roles to voices for a story.\n\nReturns a preview of voice assignments showing which voice will be used for each line.\nResolution order: line.actorId \u2192 casting[roleId] \u2192 defaultVoiceId\n\nUse this endpoint to verify voice assignments before generating audio.",
        "operationId": "render_story_endpoint_stories__storyId__render_post",
        "parameters": [
          {
            "name": "storyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Storyid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ResolvedLine"
                  },
                  "title": "Response Render Story Endpoint Stories  Storyid  Render Post"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/stories/{storyId}/generate": {
      "post": {
        "summary": "Generate Story Endpoint",
        "description": "Start audio generation for a story.\n\nOnly one job per story can be running or queued at a time.\nIf a job is already active for this story, returns 409 Conflict unless\ncancel_existing=true, in which case the active job is cancelled and a new one is started.",
        "operationId": "generate_story_endpoint_stories__storyId__generate_post",
        "parameters": [
          {
            "name": "storyId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Storyid"
            }
          },
          {
            "name": "cancel_existing",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Cancel Existing"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/GenerateRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Request"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Job"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
