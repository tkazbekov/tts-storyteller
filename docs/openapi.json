      "get": {
        "summary": "List Story Audio Files",
        "description": "List all individual audio files for a story.",
        "operationId": "list_story_audio_files_audio_stories__storyId__files_get",
        "parameters": [
          {
            "name": "storyId",
            "in": "path",
            "required": true,
            "schema": {
