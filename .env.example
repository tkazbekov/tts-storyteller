# =============================================================================
# TTS Storyteller API Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Default Backend
# -----------------------------------------------------------------------------
# Which backend to use for new voices (qwen, vibevoice)
TTS_DEFAULT_BACKEND=qwen

# -----------------------------------------------------------------------------
# Shared Settings
# -----------------------------------------------------------------------------
# GPU device to use (cuda:0, cuda:1, cpu)
TTS_DEVICE=cuda:0

# -----------------------------------------------------------------------------
# Qwen3-TTS Backend Configuration
# -----------------------------------------------------------------------------
# Base model for story generation (voice cloning)
# Size: 3.86GB, VRAM: ~4GB, Speed: Fast (~2s/line)
TTS_QWEN_BASE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base

# Voice design model for creating voices from text descriptions
# Size: 3.86GB, VRAM: ~4GB
TTS_QWEN_VOICE_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign

# Data type (bfloat16 recommended for Qwen)
TTS_QWEN_DTYPE=bfloat16

# Attention implementation (flash_attention_2 recommended for memory efficiency)
TTS_QWEN_ATTN=flash_attention_2

# Optional: Generation parameters
TTS_QWEN_MAX_NEW_TOKENS=2048
TTS_QWEN_TOP_P=0.95
TTS_QWEN_TEMPERATURE=1.0

# -----------------------------------------------------------------------------
# VibeVoice Backend Configuration
# -----------------------------------------------------------------------------
# Base model for story generation (multi-speaker, long-form)
# Options:
#   - vibevoice/VibeVoice-7B (full precision, ~19GB VRAM)
#   - DevParker/VibeVoice7b-low-vram (4-bit quantized, ~8GB VRAM) ← RECOMMENDED
# Speed: Slower (~5-10s/line due to diffusion)
TTS_VIBEVOICE_BASE_MODEL=DevParker/VibeVoice7b-low-vram

# Voice design model (not available yet for VibeVoice)
# TTS_VIBEVOICE_VOICE_DESIGN_MODEL=vibevoice/VibeVoice-Design-7B

# Data type (float16 or bfloat16)
TTS_VIBEVOICE_DTYPE=float16

# Quantization level (none, 4bit, 8bit)
# 4bit recommended for RTX 3090 to fit alongside Qwen
TTS_VIBEVOICE_QUANTIZATION=4bit

# Diffusion parameters (VibeVoice-specific)
TTS_VIBEVOICE_CFG_SCALE=3.0          # Classifier-Free Guidance scale
TTS_VIBEVOICE_DIFFUSION_STEPS=50     # Number of diffusion steps

# API key (if using cloud-based VibeVoice)
# TTS_VIBEVOICE_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
TTS_HOST=0.0.0.0
TTS_PORT=8000
TTS_CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost/tts_storyteller

# -----------------------------------------------------------------------------
# Optional: Project Root
# -----------------------------------------------------------------------------
# Auto-detected if not set
# TTS_ROOT=/path/to/tts-storyteller

# =============================================================================
# Memory Planning for RTX 3090 (24GB VRAM)
# =============================================================================
# Recommended configuration (both backends):
#   - Qwen Base + VoiceDesign (bfloat16):     8GB
#   - VibeVoice (4-bit quantized):            8GB
#   - Working memory:                         4GB
#   - Total:                                 20GB (4GB headroom)
# =============================================================================
