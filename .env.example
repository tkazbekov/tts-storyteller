# TTS Model Configuration
QWEN3_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN3_TTS_DEVICE=cuda:0
QWEN3_TTS_DTYPE=bfloat16
QWEN3_TTS_ATTN=auto
QWEN3_TTS_LANGUAGE=English

# API Configuration
QWEN3_TTS_HOST=0.0.0.0
QWEN3_TTS_PORT=8000
QWEN3_TTS_CORS_ORIGINS=*

# Project Root (optional, auto-detected from script location)
# QWEN3_TTS_ROOT=/path/to/qwen3-tts
