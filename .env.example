# TTS Storyteller API Configuration

# Default backend for newly created voices: qwen or vibevoice.
TTS_DEFAULT_BACKEND=qwen

# Shared runtime settings.
TTS_DEVICE=cuda:0
TTS_HOST=0.0.0.0
TTS_PORT=8000
TTS_CORS_ORIGINS=*

# Local Postgres used by docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://tts_storyteller:dev_password@localhost:5432/tts_storyteller

# Qwen3-TTS backend.
TTS_QWEN_BASE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
TTS_QWEN_VOICE_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
TTS_QWEN_DTYPE=bfloat16
TTS_QWEN_ATTN=flash_attention_2
TTS_QWEN_MAX_NEW_TOKENS=2048
TTS_QWEN_TOP_P=0.95
TTS_QWEN_TEMPERATURE=1.0

# VibeVoice backend. Experimental in this repo.
# Recommended low-VRAM model for 24GB GPUs:
TTS_VIBEVOICE_BASE_MODEL=DevParker/VibeVoice7b-low-vram
TTS_VIBEVOICE_DTYPE=float16
TTS_VIBEVOICE_QUANTIZATION=4bit
TTS_VIBEVOICE_CFG_SCALE=3.0
TTS_VIBEVOICE_DIFFUSION_STEPS=50

# Optional: project root. Usually auto-detected.
# TTS_ROOT=/path/to/tts-storyteller

# Optional Hugging Face settings.
# HF_TOKEN=...
# HF_HOME=/path/to/huggingface-cache
